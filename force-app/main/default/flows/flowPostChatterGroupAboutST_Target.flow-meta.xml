    <formulas>
        <name>accountId_RelChatter</name>
        <dataType>String</dataType>
        <expression>if({!isRelOpp}, {!getTargetAccountViaOpp.Account.Id}, {!getTargetAccount.Id})</expression>
    </formulas>
    <formulas>
        <description>https://goravseth.com/manipulating-text-in-flows</description>
        <name>emptyStr</name>
        <dataType>String</dataType>
        <expression>&quot;&quot;</expression>
    </formulas>
    <formulas>
        <name>isRelAccount</name>
        <dataType>Boolean</dataType>
        <expression>left({!WhatId}, 3) == &quot;001&quot;</expression>
    </formulas>
    <formulas>
        <name>isRelOpp</name>
        <dataType>Boolean</dataType>
        <expression>left({!WhatId}, 3) == &quot;006&quot;</expression>
    </formulas>
    <formulas>
        <name>isTargetPosting</name>
        <dataType>Boolean</dataType>
        <expression>OR(
    AND({!isRelAccount}, NOT(ISBLANK({!getTargetAccount.targetChatterCollaborationGroupId__c}))),
    AND({!isRelOpp}, NOT(ISBLANK( {!getTargetAccountViaOpp.Account.targetChatterCollaborationGroupId__c} )))
)</expression>
    </formulas>
    <formulas>
        <name>isTargetPostingToTeams</name>
        <dataType>Boolean</dataType>
        <expression>OR(
    AND({!isRelAccount}, NOT(ISBLANK({!getTargetAccount.targetTeamsMail__c}))),
    AND({!isRelOpp}, NOT(ISBLANK( {!getTargetAccountViaOpp.Account.targetTeamsMail__c} )))
)</expression>
    </formulas>
    <formulas>
        <name>isTargetToShareInfo</name>
        <dataType>Boolean</dataType>
        <expression>OR(
    AND({!isRelAccount}, {!getTargetAccount.isTargetToShareInfo__c}),
    AND({!isRelOpp}, {!getTargetAccountViaOpp.Account.isTargetToShareInfo__c})
)</expression>
    </formulas>
    <formulas>
        <name>mentinText_targetChatterCollaborationGroupId</name>
        <dataType>String</dataType>
        <expression>&quot;@[&quot;&amp;{!targetChatterCollaborationGroupId}&amp;&quot;]&quot;</expression>
    </formulas>
    <formulas>
        <description>0F9RC0000000Cu10AE</description>
        <name>mentionText_senryaku</name>
        <dataType>String</dataType>
        <expression>IF({!isTargetPosting}, &quot;@[0F9RC0000000Cu10AE]&quot;, &quot;&quot;)</expression>
    </formulas>
    <formulas>
        <name>mentionText_sonota</name>
        <dataType>String</dataType>
        <expression>if({!isTargetToShareInfo}, &quot;@[0F9RC0000000FWv0AM]&quot;, &quot;&quot;)</expression>
    </formulas>
    <formulas>
        <name>targetChatterCollaborationGroupId</name>
        <dataType>String</dataType>
        <expression>IF(
    {!isRelAccount_true}, {!getTargetAccount.targetChatterCollaborationGroupId__c}, 
    IF({!isRelOpp_true}, {!getTargetAccountViaOpp.Account.targetChatterCollaborationGroupId__c}, &quot;&quot;)
)</expression>
    </formulas>
    <formulas>
        <name>targetOppUrl</name>
        <dataType>String</dataType>
        <expression>IF({!isRelOpp}, 
&quot;https://forcecom175.lightning.force.com/lightning/r/Opportunity/&quot;+{!getTargetAccountViaOpp.Id}+&quot;/view&quot;,
&quot;&quot;)</expression>
    </formulas>
    <formulas>
        <name>targetRecordOwner</name>
        <dataType>String</dataType>
        <expression>IF({!isRelAccount}, 
{!getTargetAccount.Owner.LastName}+{!getTargetAccount.Owner.FirstName}, 
{!getTargetAccountViaOpp.Owner.LastName}+{!getTargetAccountViaOpp.Owner.FirstName}
)</expression>
    </formulas>
    <formulas>
        <name>targetTeamsMail</name>
        <dataType>String</dataType>
        <expression>IF(
    {!isRelAccount_true}, {!getTargetAccount.targetTeamsMail__c}, 
    IF({!isRelOpp_true}, {!getTargetAccountViaOpp.Account.targetTeamsMail__c}, &quot;&quot;)
)</expression>
    </formulas>
