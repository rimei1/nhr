    <apiVersion>64.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <assignments>
        <name>setCollectionToUpd</name>
        <label>setCollectionToUpd</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>updVal_ST_DeliveryRecord</assignToReference>
            <operator>Add</operator>
            <value>
                <elementReference>loopApplyDiscountUnit</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>loopApplyDiscountUnit</targetReference>
        </connector>
    </assignments>
    <assignments>
        <name>setUnitDiscountAmount</name>
        <label>setUnitDiscountAmount</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>loopApplyDiscountUnit.unitDiscountAmount__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>$Record.AdjustmentMoney__c</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>setCollectionToUpd</targetReference>
        </connector>
    </assignments>
    <environments>Default</environments>
    <formulas>
        <name>endDate</name>
        <dataType>Date</dataType>
        <expression>DATE(
  YEAR(TODAY()),
  MONTH(TODAY()) + 1,
  1
) - 1</expression>
    </formulas>
    <formulas>
        <name>itemNameExcluded</name>
        <dataType>String</dataType>
        <expression>&quot;値引&quot;</expression>
    </formulas>
    <formulas>
        <name>startDate</name>
        <dataType>Date</dataType>
        <expression>DATE(
  YEAR(TODAY()),
  MONTH(TODAY()),
  1
)</expression>
    </formulas>
    <interviewLabel>【現場】単価値引き額の一括適用 {!$Flow.CurrentDateTime}</interviewLabel>
    <label>【現場】単価値引き額の一括適用</label>
    <loops>
        <name>loopApplyDiscountUnit</name>
        <label>loopApplyDiscountUnit</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <collectionReference>getST_DeliveryRecord</collectionReference>
        <iterationOrder>Asc</iterationOrder>
        <nextValueConnector>
            <targetReference>setUnitDiscountAmount</targetReference>
        </nextValueConnector>
        <noMoreValuesConnector>
            <targetReference>updST_DeliveryRecord</targetReference>
        </noMoreValuesConnector>
    </loops>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordLookups>
        <name>getST_DeliveryRecord</name>
        <label>getST_DeliveryRecord</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>loopApplyDiscountUnit</targetReference>
        </connector>
        <filterLogic>1 AND 2 AND NOT(3)</filterLogic>
        <filters>
            <field>ST_field_name__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.Id</elementReference>
            </value>
        </filters>
        <filters>
            <field>BillingDate__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.targetBillingCloseDate__c</elementReference>
            </value>
        </filters>
        <filters>
            <field>ST_item__c</field>
            <operator>Contains</operator>
            <value>
                <elementReference>itemNameExcluded</elementReference>
            </value>
        </filters>
        <getFirstRecordOnly>false</getFirstRecordOnly>
        <object>ST_DeliveryRecord__c</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <recordUpdates>
        <name>updST_DeliveryRecord</name>
        <label>updST_DeliveryRecord</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <inputReference>updVal_ST_DeliveryRecord</inputReference>
    </recordUpdates>
    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>getST_DeliveryRecord</targetReference>
        </connector>
        <filterFormula>OR(

  /* 1. 新規作成時：どちらも NULL でなく、どちらかに値が入っている */
  AND(
    ISNEW(),
    NOT(ISBLANK({!$Record.AdjustmentMoney__c})),
    NOT(ISBLANK({!$Record.targetBillingCloseDate__c}))
  ),

  /* 2. 更新時：いずれかが更新され、かつ両方 NULL ではない */
  AND(
    OR(
      ISCHANGED({!$Record.AdjustmentMoney__c}),
      ISCHANGED({!$Record.targetBillingCloseDate__c})
    ),
    NOT(ISBLANK({!$Record.AdjustmentMoney__c})),
    NOT(ISBLANK({!$Record.targetBillingCloseDate__c}))
  )
)</filterFormula>
        <object>ST_ConstructionSite__c</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
    <variables>
        <name>updVal_ST_DeliveryRecord</name>
        <dataType>SObject</dataType>
        <isCollection>true</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
        <objectType>ST_DeliveryRecord__c</objectType>
    </variables>
</Flow>
