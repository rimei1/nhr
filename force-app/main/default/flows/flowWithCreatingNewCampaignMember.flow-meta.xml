    <environments>Default</environments>
    <formulas>
        <name>isAlreadyExistFirstTouchCpnInterest</name>
        <dataType>Boolean</dataType>
        <expression>OR(
    NOT( ISBLANK( {!$Record.Lead.firstCpnInterest__c} ) ), 
    NOT( ISBLANK( {!$Record.Contact.firstCpnInterest__c} ))
)</expression>
    </formulas>
    <formulas>
        <name>isAlreadyExistFirstTouchCpnSource</name>
        <dataType>Boolean</dataType>
        <expression>OR(
    NOT( ISBLANK( {!$Record.Lead.firstCpnSource__c} ) ), 
    NOT( ISBLANK( {!$Record.Contact.firstCpnSource__c} ) )
)</expression>
    </formulas>
    <formulas>
        <name>isExistContact</name>
        <dataType>Boolean</dataType>
        <expression>NOT(ISBLANK( {!$Record.ContactId} ))</expression>
    </formulas>
    <formulas>
        <name>isExistLeadId</name>
        <dataType>Boolean</dataType>
        <expression>NOT(ISBLANK( {!$Record.LeadId} ))</expression>
    </formulas>
    <formulas>
        <name>isFirstTouchTargetCpn</name>
        <dataType>Boolean</dataType>
        <expression>AND(
    TEXT( {!gettingProcessTargetCpn.Campaign.cpnType__c} ) = {!targetCpnType},
    DATEVALUE( {!gettingProcessTargetCpn.CreatedDate} ) &gt; {!startDateOfFirstTouchAssignmentFlow}
)</expression>
    </formulas>
    <formulas>
        <name>targetCpnType</name>
        <dataType>String</dataType>
        <expression>TEXT( {!$Record.Campaign.cpnType__c} )</expression>
    </formulas>
    <formulas>
        <name>targetRecordUUID</name>
        <dataType>String</dataType>
        <expression>IF(ISBLANK( {!$Record.ContactId} ), {!$Record.LeadId}, {!$Record.ContactId})</expression>
    </formulas>
