        <locationY>1223</locationY>
        <defaultConnectorLabel>デフォルトの結果</defaultConnectorLabel>
        <rules>
            <name>trueCaseIsExistLeadId</name>
            <conditionLogic>1 AND 2 AND (3 OR 4)</conditionLogic>
