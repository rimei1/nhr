    <formulas>
        <name>fCurTotalPrice</name>
        <dataType>Currency</dataType>
        <expression>{!fCurUnitPrice} * {!$Record.Quantity}</expression>
        <scale>0</scale>
    </formulas>
    <formulas>
        <name>fCurUnitPrice</name>
        <dataType>Currency</dataType>
        <expression>IF (ISBLANK({!$Record.DiscountAmount__c}), {!$Record.ListPrice}, {!$Record.ListPrice} - {!$Record.DiscountAmount__c})</expression>
        <scale>0</scale>
    </formulas>
