    <description>【納入実績】非製品ソート順割り当て処理</description>
    <environments>Default</environments>
    <formulas>
        <name>firstIndex</name>
        <dataType>Number</dataType>
        <expression>{!inputStartIndex}+{!inputSortOrderIncrementStep}</expression>
        <scale>2</scale>
    </formulas>
    <formulas>
        <name>newSortOrder</name>
        <dataType>Number</dataType>
        <expression>IF(
  CONTAINS({!loopTargetCollection.ST_item__c}, &quot;値引&quot;),
  99,
  IF(
    OR(
        CONTAINS({!loopTargetCollection.ST_item__c}, &quot;運搬費&quot;),
        CONTAINS({!loopTargetCollection.ST_item__c}, &quot;運送費&quot;)
    ),
    95,
    IF(
      CONTAINS({!loopTargetCollection.ST_item__c}, &quot;ユニック&quot;),
      96,
      IF(
        CONTAINS({!loopTargetCollection.ST_item__c}, &quot;宅急便&quot;),
        97,
        IF(
          OR(
            {!loopTargetCollection.ST_item__c} = &quot;異形棒鋼&quot;,
            CONTAINS({!loopTargetCollection.ST_item__c}, &quot;異形丸鋼&quot;)
          ),
          1,
          IF(
            OR(
              CONTAINS({!loopTargetCollection.ST_item__c}, &quot;ネジ鉄筋&quot;),
              CONTAINS({!loopTargetCollection.ST_item__c}, &quot;ﾈｼﾞ鉄筋&quot;)
            ),
            2,
            NULL
          )
        )
      )
    )
  )
)</expression>
        <scale>0</scale>
    </formulas>
    <formulas>
        <name>newValueToFlowUpdateOccurred</name>
        <dataType>Boolean</dataType>
        <expression>NOT({!loopTargetCollection.flowUpdateOccurred__c})</expression>
    </formulas>
