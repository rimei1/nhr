<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>62.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <decisions>
        <name>UpdAccoutChk</name>
        <label>取引先更新チェック</label>
        <locationX>182</locationX>
        <locationY>431</locationY>
        <defaultConnectorLabel>デフォルトの結果</defaultConnectorLabel>
        <rules>
            <name>UpdAccout</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.ThemeHearingDay__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.SDGHearingDay__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.BuildingHouseHearingDay__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>UpdAccoutDate</targetReference>
            </connector>
            <label>取引先更新</label>
        </rules>
    </decisions>
    <environments>Default</environments>
    <formulas>
        <name>BuildingHouseHearingDay</name>
        <dataType>Date</dataType>
        <expression>IF ( ISNULL({!$Record.BuildingHouseHearingDay__c})
,IF( AND(NOT(ISBLANK({!$Record.period05__c})),NOT(ISBLANK({!$Record.period06__c})),NOT(ISBLANK({!$Record.period07__c}))) , TODAY() ,NULL)
,{!$Record.BuildingHouseHearingDay__c}  )</expression>
    </formulas>
    <formulas>
        <name>SDGHearingDay</name>
        <dataType>Date</dataType>
        <expression>IF ( ISNULL({!$Record.SDGHearingDay__c})
,IF( NOT(ISBLANK({!$Record.SDG__c})) , TODAY() ,NULL)
,{!$Record.SDGHearingDay__c}  )</expression>
    </formulas>
    <formulas>
        <name>ThemeHearingDay</name>
        <dataType>Date</dataType>
        <expression>IF ( ISNULL({!$Record.ThemeHearingDay__c})
,IF( OR(NOT(ISBLANK({!$Record.businessD__c})),NOT(ISBLANK({!$Record.constructionD__c}))) , TODAY() ,NULL)
,{!$Record.ThemeHearingDay__c}  )</expression>
    </formulas>
    <interviewLabel>【課題ヒアリング】 {!$Flow.CurrentDateTime}</interviewLabel>
    <label>【課題ヒアリング】ヒアリング日設定</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordUpdates>
        <name>HearingDayUpd</name>
        <label>ヒアリング日更新</label>
        <locationX>182</locationX>
        <locationY>323</locationY>
        <connector>
            <targetReference>UpdAccoutChk</targetReference>
        </connector>
        <inputAssignments>
            <field>BuildingHouseHearingDay__c</field>
            <value>
                <elementReference>BuildingHouseHearingDay</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>SDGHearingDay__c</field>
            <value>
                <elementReference>SDGHearingDay</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>ThemeHearingDay__c</field>
            <value>
                <elementReference>ThemeHearingDay</elementReference>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <recordUpdates>
        <name>UpdAccoutDate</name>
        <label>取引先更新</label>
        <locationX>50</locationX>
        <locationY>539</locationY>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Id</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.Account__c</elementReference>
            </value>
        </filters>
        <inputAssignments>
            <field>HearingDoneDay__c</field>
            <value>
                <elementReference>$Flow.CurrentDate</elementReference>
            </value>
        </inputAssignments>
        <object>Account</object>
    </recordUpdates>
    <start>
        <locationX>56</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>HearingDayUpd</targetReference>
        </connector>
        <filterFormula>AND(ISNULL({!$Record.Account__r.HearingDoneDay__c}) 
,OR( ISNEW() 
, ISCHANGED({!$Record.constructionD__c})
, ISCHANGED({!$Record.businessD__c})
, ISCHANGED({!$Record.SDG__c})
, ISCHANGED({!$Record.period05__c})
, ISCHANGED({!$Record.period06__c})
, ISCHANGED({!$Record.period07__c}) ) )</filterFormula>
        <object>IssueHearing__c</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
</Flow>
