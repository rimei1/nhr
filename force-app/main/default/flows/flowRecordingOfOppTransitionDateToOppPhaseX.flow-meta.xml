    <formulas>
        <name>isUpdFirstEstimates</name>
        <dataType>Boolean</dataType>
        <expression>AND(
    OR(
        TEXT({!$Record__Prior.StageName}) = &quot;未着手&quot;,
        TEXT({!$Record__Prior.StageName}) = &quot;訪問1回目&quot;
    ),
    OR(
        TEXT({!$Record.StageName}) = &quot;初回見積提出&quot;,
        TEXT({!$Record.StageName}) = &quot;得意先検討中&quot;,
        TEXT({!$Record.StageName}) = &quot;トライアル&quot;,
        TEXT({!$Record.StageName}) = &quot;スペックアウト&quot;,
        TEXT({!$Record.StageName}) = &quot;検討保留&quot;,
        TEXT({!$Record.StageName}) = &quot;不採用&quot;,
        TEXT({!$Record.StageName}) = &quot;採用（受注）&quot;
    )
)</expression>
    </formulas>
    <formulas>
        <name>isUpdItemXxxKGI</name>
        <dataType>Boolean</dataType>
        <expression>AND(
    OR(
        TEXT({!$Record__Prior.StageName}) = &quot;未着手&quot;,
        TEXT({!$Record__Prior.StageName}) = &quot;訪問1回目&quot;,
        TEXT({!$Record__Prior.StageName}) = &quot;初回見積提出&quot;,
        TEXT({!$Record__Prior.StageName}) = &quot;得意先検討中&quot;,
        TEXT({!$Record__Prior.StageName}) = &quot;トライアル&quot;,
        TEXT({!$Record__Prior.StageName}) = &quot;購買決定者検討中&quot;,
        TEXT({!$Record__Prior.StageName}) = &quot;採用一歩手前&quot;,
        TEXT({!$Record__Prior.StageName}) = &quot;停滞保留中&quot;,
        TEXT({!$Record__Prior.StageName}) = &quot;検討保留&quot;
    ),
    OR(
        TEXT({!$Record.StageName}) = &quot;採用（受注）&quot;
    )
)</expression>
    </formulas>
