    <formulas>
        <name>categoryTextRaw</name>
        <dataType>String</dataType>
        <expression>IF({!isStructuralProposed}, &quot;構造関連;&quot;, &quot;&quot;) &amp;
IF({!isReadyMixedConcreteProposed}, &quot;生コン;&quot;, &quot;&quot;) &amp;
IF({!isRebarProposed}, &quot;鉄筋;&quot;, &quot;&quot;) &amp;
IF({!isInsulationProposed}, &quot;断熱材;&quot;, &quot;&quot;) &amp;
IF({!isGypsumBoardProposed}, &quot;石膏ボード;&quot;, &quot;&quot;) &amp;
IF({!isLightGaugeSteelProposed}, &quot;軽天材;&quot;, &quot;&quot;) &amp;
IF({!isOtherProposed}, &quot;その他;&quot;, &quot;&quot;)</expression>
    </formulas>
    <formulas>
        <name>isCatGypsumBoard</name>
        <dataType>Boolean</dataType>
        <expression>TEXT({!loopEvaluateJuProposedProducts.Category__c}) = &quot;石膏ボード&quot;</expression>
    </formulas>
    <formulas>
        <name>isCatInsulation</name>
        <dataType>Boolean</dataType>
        <expression>OR(
  TEXT({!loopEvaluateJuProposedProducts.Category__c}) = &quot;床断熱材&quot;,
  TEXT({!loopEvaluateJuProposedProducts.Category__c}) = &quot;壁天断熱材&quot;,
  TEXT({!loopEvaluateJuProposedProducts.Category__c}) = &quot;床壁天断熱材&quot;
)</expression>
    </formulas>
    <formulas>
        <name>isCatLightGaugeSteel</name>
        <dataType>Boolean</dataType>
        <expression>TEXT({!loopEvaluateJuProposedProducts.Category__c}) = &quot;軽天材&quot;</expression>
    </formulas>
    <formulas>
        <name>isCatReadyMixedConcrete</name>
        <dataType>Boolean</dataType>
        <expression>TEXT({!loopEvaluateJuProposedProducts.Category__c}) = &quot;生コン&quot;</expression>
    </formulas>
    <formulas>
        <name>isCatRebar</name>
        <dataType>Boolean</dataType>
        <expression>TEXT({!loopEvaluateJuProposedProducts.Category__c}) = &quot;鉄筋&quot;</expression>
    </formulas>
    <formulas>
        <name>isCatStructural</name>
        <dataType>Boolean</dataType>
        <expression>OR(
  TEXT({!loopEvaluateJuProposedProducts.Category__c}) = &quot;作図積算BPO&quot;,
  TEXT({!loopEvaluateJuProposedProducts.Category__c}) = &quot;構造プレカット&quot;,
  TEXT({!loopEvaluateJuProposedProducts.Category__c}) = &quot;構造パネル&quot;,
  TEXT({!loopEvaluateJuProposedProducts.Category__c}) = &quot;羽柄材&quot;,
  TEXT({!loopEvaluateJuProposedProducts.Category__c}) = &quot;構造その他&quot;
)</expression>
    </formulas>
    <formulas>
        <name>isOther</name>
        <dataType>Boolean</dataType>
        <expression>NOT(
  OR(
    {!isCatStructural},
    {!isCatReadyMixedConcrete},
    {!isCatRebar},
    {!isCatInsulation},
    {!isCatGypsumBoard},
    {!isCatLightGaugeSteel}
  )
)</expression>
    </formulas>
    <formulas>
        <name>newValueToSixCategoryProposedProducts</name>
        <dataType>String</dataType>
        <expression>IF(
  LEN({!categoryTextRaw}) &gt; 0,
  LEFT({!categoryTextRaw}, LEN({!categoryTextRaw}) - 1),
  &quot;&quot;
)</expression>
    </formulas>
    <formulas>
