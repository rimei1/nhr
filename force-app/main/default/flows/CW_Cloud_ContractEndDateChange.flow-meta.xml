        <locationX>182</locationX>
        <locationY>323</locationY>
        <defaultConnector>
            <targetReference>ContractEndDateUpd2</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>契約更新日なし</defaultConnectorLabel>
        <rules>
            <name>ContractDateIs</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.RenewalContractDate__c</leftValueReference>
