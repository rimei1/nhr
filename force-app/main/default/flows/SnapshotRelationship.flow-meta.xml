<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>53.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <decisions>
        <name>IsTriggerDateStartOfMonth</name>
        <label>起動日は月初か</label>
        <locationX>182</locationX>
        <locationY>276</locationY>
        <defaultConnectorLabel>いいえ</defaultConnectorLabel>
        <rules>
            <name>True</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>StartOfDay</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <numberValue>1.0</numberValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>createSnapshotRelationship</targetReference>
            </connector>
            <label>はい</label>
        </rules>
    </decisions>
    <formulas>
        <name>StartOfDay</name>
        <dataType>Number</dataType>
        <expression>DAY(TODAY())</expression>
        <scale>0</scale>
    </formulas>
    <formulas>
        <name>TargetDate_Text</name>
        <dataType>String</dataType>
        <expression>CASE(MONTH(TODAY()),
     1, TEXT(YEAR(TODAY())-1) &amp; &apos;年&apos; &amp; &apos;12月&apos;,
     TEXT(YEAR(TODAY())) &amp; &apos;年&apos; &amp; TEXT(MONTH(TODAY())-1) &amp; &apos;月&apos;
)</expression>
    </formulas>
    <interviewLabel>関係構築度スナップショット {!$Flow.CurrentDateTime}</interviewLabel>
    <label>関係構築度スナップショット</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordCreates>
        <name>createSnapshotRelationship</name>
        <label>関係構築度スナップショット作成</label>
        <locationX>50</locationX>
        <locationY>396</locationY>
        <inputAssignments>
            <field>Contact__c</field>
            <value>
                <elementReference>$Record.Id</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Date_Text__c</field>
            <value>
                <elementReference>TargetDate_Text</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Snapshoted_Relationship__c</field>
            <value>
                <elementReference>$Record.RelationshipDegree__c</elementReference>
            </value>
        </inputAssignments>
        <object>Snapshot_Relationship__c</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordCreates>
    <start>
        <locationX>56</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>IsTriggerDateStartOfMonth</targetReference>
        </connector>
        <object>Contact</object>
        <schedule>
            <frequency>Daily</frequency>
            <startDate>2021-12-13</startDate>
            <startTime>12:00:00.000Z</startTime>
        </schedule>
        <triggerType>Scheduled</triggerType>
    </start>
    <status>Active</status>
</Flow>
