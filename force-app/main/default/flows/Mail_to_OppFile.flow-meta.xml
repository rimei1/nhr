    <decisions>
        <name>RelatedOpp_YesNo</name>
        <label>関連先に商談が紐付いているか？</label>
        <locationX>259</locationX>
        <locationY>539</locationY>
        <defaultConnector>
            <targetReference>Get_ToAddress</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>商談なし</defaultConnectorLabel>
        <rules>
            <name>Opp_Yes</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.RelatedToId</leftValueReference>
                <operator>StartsWith</operator>
                <rightValue>
                    <stringValue>006</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Create_Opp_File</targetReference>
            </connector>
            <label>商談あり</label>
        </rules>
    </decisions>
