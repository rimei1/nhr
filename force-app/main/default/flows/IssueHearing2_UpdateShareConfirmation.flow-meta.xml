<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>65.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <decisions>
        <name>IsTargetSupplierSelected</name>
        <label>材工発注 or 未使用が入っているか</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>X1</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>NO</defaultConnectorLabel>
        <rules>
            <name>YES</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>$Record.main_vendor1__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>001RC00000eg4IVYAY</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.main_vendor2__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>001RC00000eg4IVYAY</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.main_vendor3__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>001RC00000eg4IVYAY</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.main_vendor1__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>001RC00000egUlpYAE</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.main_vendor2__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>001RC00000egUlpYAE</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.main_vendor3__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>001RC00000egUlpYAE</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>X1</targetReference>
            </connector>
            <label>YES</label>
        </rules>
    </decisions>
    <environments>Default</environments>
    <interviewLabel>【課題ヒアリング（見積作成/発注形態）】 {!$Flow.CurrentDateTime}</interviewLabel>
    <label>【課題ヒアリング（見積作成/発注形態）】シェア確認完了日更新</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordUpdates>
        <name>X1</name>
        <label>シェア確認完了日を更新</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <filterLogic>and</filterLogic>
        <filters>
            <field>ShareConfirmation__c</field>
            <operator>IsNull</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <inputAssignments>
            <field>ShareConfirmation__c</field>
            <value>
                <elementReference>$Flow.CurrentDate</elementReference>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>IsTargetSupplierSelected</targetReference>
        </connector>
        <filterLogic>1 AND (2 or 3 or 4)</filterLogic>
        <filters>
            <field>ShareConfirmation__c</field>
            <operator>IsNull</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <filters>
            <field>main_vendor1__c</field>
            <operator>IsNull</operator>
            <value>
                <booleanValue>false</booleanValue>
            </value>
        </filters>
        <filters>
            <field>main_vendor2__c</field>
            <operator>IsNull</operator>
            <value>
                <booleanValue>false</booleanValue>
            </value>
        </filters>
        <filters>
            <field>main_vendor3__c</field>
            <operator>IsNull</operator>
            <value>
                <booleanValue>false</booleanValue>
            </value>
        </filters>
        <object>IssueHearing2__c</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
    <triggerOrder>500</triggerOrder>
</Flow>
