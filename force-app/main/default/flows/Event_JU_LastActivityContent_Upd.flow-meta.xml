<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>59.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <decisions>
        <name>updChk</name>
        <label>更新チェック</label>
        <locationX>314</locationX>
        <locationY>431</locationY>
        <defaultConnectorLabel>デフォルトの結果</defaultConnectorLabel>
        <rules>
            <name>updChkOpp</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>GetNewActive</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>GetNewActive.WhatId</leftValueReference>
                <operator>StartsWith</operator>
                <rightValue>
                    <stringValue>006</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Upd</targetReference>
            </connector>
            <label>商談</label>
        </rules>
        <rules>
            <name>updChkThema</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>GetNewActive</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>GetNewActive.WhatId</leftValueReference>
                <operator>StartsWith</operator>
                <rightValue>
                    <stringValue>a2g</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>UpdateThema</targetReference>
            </connector>
            <label>テーマ</label>
        </rules>
    </decisions>
    <environments>Default</environments>
    <formulas>
        <name>LastActivityContent</name>
        <dataType>String</dataType>
        <expression>IF ( NOT( ISBLANK({!$Record.AccountTask2__c})) , {!$Record.AccountTask2__c} ,{!$Record.AccountTask1__c})</expression>
    </formulas>
    <formulas>
        <name>StartDateOnly</name>
        <dataType>Date</dataType>
        <expression>DATEVALUE({!GetNewActive.StartDateTime})</expression>
    </formulas>
    <interviewLabel>最終活動内容更新 {!$Flow.CurrentDateTime}</interviewLabel>
    <label>【行動】最終活動内容更新</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordLookups>
        <name>GetNewActive</name>
        <label>最新活動取得</label>
        <locationX>314</locationX>
        <locationY>323</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>updChk</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>WhatId</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.WhatId</elementReference>
            </value>
        </filters>
        <getFirstRecordOnly>true</getFirstRecordOnly>
        <object>Event</object>
        <sortField>StartDateTime</sortField>
        <sortOrder>Desc</sortOrder>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <recordUpdates>
        <name>Upd</name>
        <label>商談_最終活動内容更新</label>
        <locationX>50</locationX>
        <locationY>539</locationY>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Id</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.WhatId</elementReference>
            </value>
        </filters>
        <inputAssignments>
            <field>JU_LastActivityContent__c</field>
            <value>
                <elementReference>OpportunityCom</elementReference>
            </value>
        </inputAssignments>
        <object>Opportunity</object>
    </recordUpdates>
    <recordUpdates>
        <name>UpdateThema</name>
        <label>テーマ_最終活動内容更新</label>
        <locationX>314</locationX>
        <locationY>539</locationY>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Id</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.WhatId</elementReference>
            </value>
        </filters>
        <inputAssignments>
            <field>LastActivityContent__c</field>
            <value>
                <elementReference>OpportunityCom</elementReference>
            </value>
        </inputAssignments>
        <object>Theme__c</object>
    </recordUpdates>
    <start>
        <locationX>188</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>GetNewActive</targetReference>
        </connector>
        <filterFormula>BEGINS({!$Record.WhatId},&apos;006&apos;)||BEGINS({!$Record.WhatId},&apos;a2g&apos;)</filterFormula>
        <object>Event</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
    <textTemplates>
        <description>最終の活動内容を商談に更新</description>
        <name>OpportunityCom</name>
        <isViewedAsPlainText>true</isViewedAsPlainText>
        <text>{!StartDateOnly}
件名：{!GetNewActive.Subject}
説明：{!GetNewActive.Description}</text>
    </textTemplates>
</Flow>
