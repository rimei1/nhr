public class NHR_SummaryApprovedCtrl{
    public class Request {
        @InvocableVariable public Id SummaryReportId;
        @InvocableVariable public String CommentStr;
    }
    @InvocableMethod(label='日報承認処理')
    public static List<String> NHR_Approved(List<Request> requests) {
        List<String> srclist = New List<String>();
        for(Request obj : requests) {
            String src = '';
            String CommentSetStr = obj.CommentStr == NULL ? '' : obj.CommentStr;
            // 1. 承認インスタンスを取得（ProcessInstance）
            List<ProcessInstance> instances = [
                SELECT Id 
                FROM ProcessInstance 
                WHERE TargetObjectId = :obj.SummaryReportId 
                ORDER BY CreatedDate DESC 
                LIMIT 1
            ];
            
            if (!instances.isEmpty()) {
                Id processInstanceId = instances[0].Id;
                
                // 2. 関連するワークアイテム（承認アクションのID＝04i〜）を取得
                List<ProcessInstanceWorkitem> items = [
                    SELECT Id, ActorId, CreatedDate, ProcessInstanceId 
                    FROM ProcessInstanceWorkitem 
                    WHERE ProcessInstanceId = :processInstanceId
                    LIMIT 1
                ];
                
                if (!items.isEmpty()) {
                    Id workItemId = items[0].Id; // ← これが 04i で始まるワークアイテムID
                    Approval.ProcessWorkitemRequest req = new Approval.ProcessWorkitemRequest();
                    req.setComments(CommentSetStr);
                    req.setAction('Approve');
                    req.setWorkitemId(workItemId); // 日報ID
                    
                    Approval.ProcessResult result = Approval.process(req);
                    src = '承認済';
                } else {
                    src = '承認申請されていません。';
                    System.debug('ワークアイテムが見つかりませんでした');
                }
                
            } else {
                src = '承認申請されていません。';
                System.debug('承認インスタンスが見つかりませんでした');
            }
            srclist.add(src);
        }
        return srclist;
    }
    
