<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>IsShareTotalValid__c</fullName>
    <formula>ABS(
  BLANKVALUE(PrincipalSuppliersShare1__c, 0) +
  BLANKVALUE(PrincipalSuppliersShare2__c, 0) +
  BLANKVALUE(PrincipalSuppliersShare3__c, 0) - 1
) &lt; 0.01</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>/シェア率判定</label>
    <trackTrending>false</trackTrending>
    <type>Checkbox</type>
</CustomField>
