<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>ThisMonthComplete__c</fullName>
    <description>今月完了予定日を迎える商談であればTrue</description>
    <formula>AND(MONTH(CloseDate )=MONTH(TODAY()) ,YEAR(CloseDate)=YEAR(TODAY()))</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>*今月完了予定日フラグ（数式）</label>
    <trackHistory>false</trackHistory>
    <type>Checkbox</type>
</CustomField>
