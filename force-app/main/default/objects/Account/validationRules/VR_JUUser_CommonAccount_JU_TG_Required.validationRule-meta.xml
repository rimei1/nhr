<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>VR_JUUser_CommonAccount_JU_TG_Required</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
    ISNEW(),
    RecordType.DeveloperName = &quot;CommonRecordType&quot;,
    $Profile.Name = &quot;住環境&quot;,
    ISBLANK(TEXT(JU_TG__c))
)</errorConditionFormula>
    <errorDisplayField>JU_TG__c</errorDisplayField>
    <errorMessage>TG_JUは必須項目です。入力してください。</errorMessage>
</ValidationRule>
