<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>RetirementFlgCheck</fullName>
    <active>false</active>
    <errorConditionFormula>AND((TEXT(RetirementFlg__c) =&quot;異動&quot;||TEXT(RetirementFlg__c) =&quot;退職&quot;),  RetirementDate__c  &lt;&gt;LastModifiedDate)</errorConditionFormula>
    <errorDisplayField>RetirementFlg__c</errorDisplayField>
    <errorMessage>異動・退職されている方の変更は出来ません。</errorMessage>
</ValidationRule>
