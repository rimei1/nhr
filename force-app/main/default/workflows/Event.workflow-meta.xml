    <fieldUpdates>
        <fullName>UpdateJU_VisitCount</fullName>
        <description>種別がWEB面談・訪問の場合はカウント1をセット</description>
        <field>JU_VisitCount__c</field>
        <formula>IF(
AND(
OR(
MONTH(today())&gt;=7 &amp;&amp;
YEAR(ActivityDate)= YEAR(today()) &amp;&amp; MONTH(ActivityDate)&gt;=7,
MONTH(today())&gt;=7 &amp;&amp;
YEAR(ActivityDate)=YEAR(today())+1  &amp;&amp; MONTH(ActivityDate)&lt;=6,
MONTH(today())&lt;=6 &amp;&amp;
YEAR(ActivityDate)=YEAR(today())-1 &amp;&amp; MONTH(ActivityDate)&gt;=7,
MONTH(today())&lt;=6 &amp;&amp;
YEAR(ActivityDate)=YEAR(today()),MONTH(ActivityDate)&lt;=6
),
OR(TEXT( Type )=&quot;WEB面談&quot;,TEXT( Type )=&quot;訪問&quot;)),
1,0)</formula>
        <name>【行動】訪問カウント</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Formula</operation>
        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
    </fieldUpdates>
    <rules>
        <fullName>%E3%80%90行動%E3%80%91作成%E3%83%BB編集時</fullName>
