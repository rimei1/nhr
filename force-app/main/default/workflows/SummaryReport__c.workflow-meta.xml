<?xml version="1.0" encoding="UTF-8"?>
<Workflow xmlns="http://soap.sforce.com/2006/04/metadata">
    <alerts>
        <fullName>WeeklyReportApproved</fullName>
        <description>【承認申請】承認完了メール配信</description>
        <protected>false</protected>
        <recipients>
            <type>owner</type>
        </recipients>
        <senderType>CurrentUser</senderType>
        <template>ApprovalFolder/WeeklyReportApproved</template>
    </alerts>
    <alerts>
        <fullName>WeeklyReportRejected</fullName>
        <description>【承認申請】却下メール配信</description>
        <protected>false</protected>
        <recipients>
            <type>accountOwner</type>
        </recipients>
        <senderType>CurrentUser</senderType>
        <template>ApprovalFolder/WeeklyReportRejected</template>
    </alerts>
    <fieldUpdates>
        <fullName>ActionFieldUpdate_checkbox</fullName>
        <field>nippou_shinsei__c</field>
        <literalValue>1</literalValue>
        <name>チェックボックスに✓</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Literal</operation>
        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
    </fieldUpdates>
    <fieldUpdates>
        <fullName>ActionFieldUpdate_nippousinseibi</fullName>
        <field>ju_nippou_shinseibi__c</field>
        <formula>Today()</formula>
        <name>日報申請日更新</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Formula</operation>
        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
    </fieldUpdates>
    <fieldUpdates>
        <fullName>NiPlus1</fullName>
        <field>Department__c</field>
        <formula>CreatedBy.Department</formula>
        <name>【日報】部署追加</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Formula</operation>
        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
    </fieldUpdates>
    <fieldUpdates>
        <fullName>SummaryReport_SetApprovalFlgTrue</fullName>
        <field>Approval__c</field>
        <literalValue>1</literalValue>
        <name>週報・日報：承認true</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Literal</operation>
        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
    </fieldUpdates>
    <rules>
        <fullName>%E3%80%90日報%E3%80%91担当部署更新</fullName>
        <actions>
            <name>NiPlus1</name>
            <type>FieldUpdate</type>
        </actions>
        <active>false</active>
        <criteriaItems>
            <field>SummaryReport__c.CreatedById</field>
            <operation>notEqual</operation>
        </criteriaItems>
        <description>所有者が所属している部署を自動的に反映する</description>
        <triggerType>onAllChanges</triggerType>
    </rules>
</Workflow>
