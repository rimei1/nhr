<?xml version="1.0" encoding="UTF-8"?>
<Workflow xmlns="http://soap.sforce.com/2006/04/metadata">
    <alerts>
        <fullName>ActionEmail</fullName>
        <description>フェーズ変更通知</description>
        <protected>false</protected>
        <recipients>
            <field>CW_OwnerMail__c</field>
            <type>email</type>
        </recipients>
        <senderType>CurrentUser</senderType>
        <template>CW_mailt1/CS_PhaseEDCBA</template>
    </alerts>
    <alerts>
        <fullName>AssetEndDateSendMail</fullName>
        <ccEmails>nohara@vdc-solution.jp</ccEmails>
        <description>【お知らせメール】契約終了日２ヶ月前</description>
        <protected>false</protected>
        <senderType>CurrentUser</senderType>
        <template>unfiled$public/AssetEndDateSendMail</template>
    </alerts>
    <alerts>
        <fullName>all_Phase</fullName>
        <description>全てのフェーズで通知</description>
        <protected>false</protected>
        <recipients>
            <field>CW_OwnerMail__c</field>
            <type>email</type>
        </recipients>
        <senderType>DefaultWorkflowUser</senderType>
        <template>CW_mailt1/CS_PhaseEDCBA</template>
    </alerts>
    <alerts>
        <fullName>cw_mailalart_mitsumorikakuninbi</fullName>
        <description>CSWEB_見積確認日通知</description>
        <protected>false</protected>
        <recipients>
            <type>owner</type>
        </recipients>
        <senderType>CurrentUser</senderType>
        <template>CW_mailt1/cw_mailtemple_mitsumorikakuninbi</template>
    </alerts>
    <fieldUpdates>
        <fullName>ActionFieldUpdate</fullName>
        <description>過去日付を選択しても完了予定日が本日となる不具合対策</description>
        <field>CloseDate</field>
        <formula>Priorvalue(CloseDate)</formula>
        <name>過去日付選択</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Formula</operation>
        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
    </fieldUpdates>
    <fieldUpdates>
        <fullName>ActionFieldUpdate1</fullName>
        <description>完了予定日自動追加を行う</description>
        <field>CloseDate</field>
        <formula>DATE(3000,1,1)</formula>
        <name>完了予定日自動追加</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Formula</operation>
        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
    </fieldUpdates>
    <fieldUpdates>
        <fullName>ActionFieldUpdate2</fullName>
        <field>StageName</field>
        <literalValue>商談成立確定</literalValue>
        <name>フェーズ変更</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Literal</operation>
        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
    </fieldUpdates>
    <fieldUpdates>
        <fullName>DepartmentUserUpdate</fullName>
        <field>Department__c</field>
        <formula>Owner.Department</formula>
        <name>【商談】部署更新</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Formula</operation>
        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
    </fieldUpdates>
    <fieldUpdates>
        <fullName>JU_OppAmountUpdate</fullName>
        <field>Amount</field>
        <formula>JU_AmountStack__c</formula>
        <name>【商談】金額に積上げ金額反映</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Formula</operation>
        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
    </fieldUpdates>
    <fieldUpdates>
        <fullName>JU_OppEmploymentAmountUpdate</fullName>
        <field>JU_PlanEmploymentAmount__c</field>
        <formula>JU_EmploymentAmountStack__c</formula>
        <name>【商談】採用金額（千円）に採用金額（積上げ）反映</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Formula</operation>
        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
    </fieldUpdates>
    <fieldUpdates>
        <fullName>OppotunityThisMonthCompleteFlag</fullName>
        <field>ThisMonthComplete2__c</field>
        <literalValue>1</literalValue>
        <name>【商談】今月完了予定日フラグ反映</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Literal</operation>
        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
    </fieldUpdates>
    <rules>
        <fullName>%E3%80%90商談%E3%80%91今月完了予定日フラグチェック時</fullName>
        <actions>
            <name>OppotunityThisMonthCompleteFlag</name>
            <type>FieldUpdate</type>
        </actions>
        <active>false</active>
        <criteriaItems>
            <field>Opportunity.ThisMonthComplete__c</field>
            <operation>equals</operation>
            <value>True</value>
        </criteriaItems>
        <triggerType>onCreateOrTriggeringUpdate</triggerType>
    </rules>
    <rules>
        <fullName>%E3%80%90商談%E3%80%91作成%E3%83%BB編集時</fullName>
        <actions>
            <name>DepartmentUserUpdate</name>
            <type>FieldUpdate</type>
        </actions>
        <active>false</active>
        <criteriaItems>
            <field>Opportunity.CreatedDate</field>
            <operation>notEqual</operation>
        </criteriaItems>
        <triggerType>onAllChanges</triggerType>
    </rules>
    <rules>
        <fullName>%E3%80%90商談%E3%80%91作成%E3%83%BB編集時%EF%BC%88住環境%EF%BC%89</fullName>
        <actions>
            <name>JU_OppAmountUpdate</name>
            <type>FieldUpdate</type>
        </actions>
        <active>false</active>
        <criteriaItems>
            <field>Opportunity.CreatedDate</field>
            <operation>notEqual</operation>
        </criteriaItems>
        <criteriaItems>
            <field>Opportunity.RecordTypeId</field>
            <operation>equals</operation>
            <value>住環境</value>
        </criteriaItems>
        <triggerType>onAllChanges</triggerType>
    </rules>
    <rules>
        <fullName>%E3%80%90商談%E3%80%91完了予定日不具合</fullName>
        <actions>
            <name>ActionFieldUpdate</name>
            <type>FieldUpdate</type>
        </actions>
        <active>false</active>
        <criteriaItems>
            <field>Opportunity.IsWon</field>
            <operation>equals</operation>
            <value>True</value>
        </criteriaItems>
        <description>過去日付を指定しても完了予定日が本日になる不具合対策</description>
        <triggerType>onCreateOrTriggeringUpdate</triggerType>
    </rules>
    <rules>
        <fullName>D以降フェーズ変更で通知</fullName>
        <actions>
            <name>ActionEmail</name>
            <type>Alert</type>
        </actions>
        <active>false</active>
        <criteriaItems>
            <field>Opportunity.StageName</field>
            <operation>equals</operation>
            <value>D(見積提出),C(見積1回目),B(見積2回目),A (受注),E (失注)</value>
        </criteriaItems>
        <criteriaItems>
            <field>Opportunity.RecordTypeId</field>
            <operation>equals</operation>
            <value>CSWEB</value>
        </criteriaItems>
        <description>D以降フェーズ変更で通知</description>
        <triggerType>onAllChanges</triggerType>
    </rules>
    <rules>
        <fullName>全てのフェーズで通知</fullName>
        <actions>
            <name>all_Phase</name>
            <type>Alert</type>
        </actions>
        <active>false</active>
        <criteriaItems>
            <field>Opportunity.StageName</field>
            <operation>equals</operation>
            <value>Z(新規問合),Y(お礼電話),X(積算中),W(仕入見積依頼),V(見積作成中)</value>
        </criteriaItems>
        <criteriaItems>
            <field>Opportunity.all_Phase__c</field>
            <operation>equals</operation>
            <value>True</value>
        </criteriaItems>
        <criteriaItems>
            <field>Opportunity.RecordTypeId</field>
            <operation>equals</operation>
            <value>CSWEB</value>
        </criteriaItems>
        <triggerType>onAllChanges</triggerType>
    </rules>
    <rules>
        <fullName>完了予定日自動更新</fullName>
        <actions>
            <name>ActionFieldUpdate1</name>
            <type>FieldUpdate</type>
        </actions>
        <active>false</active>
        <criteriaItems>
            <field>Opportunity.CloseDate</field>
            <operation>notEqual</operation>
        </criteriaItems>
        <criteriaItems>
            <field>Opportunity.RecordTypeId</field>
            <operation>equals</operation>
            <value>野原エンジニアリング【ゼネコン】</value>
        </criteriaItems>
        <triggerType>onCreateOnly</triggerType>
    </rules>
</Workflow>
