      <td class="footer-bank-label">口　座　番　号</td>
      <td class="footer-bank-val">普通　1182458</td>
    </tr>
    <tr>
      <td class="footer-bank-label">口　座　名　義</td>
      <td class="footer-bank-val">ノハラスチール㈱</td>
    </tr>
  </table>

  <!-- ページ番号 -->
  <div class="page-footer" style="text-align: center;">1 / 1</div>

</body>
</apex:page>