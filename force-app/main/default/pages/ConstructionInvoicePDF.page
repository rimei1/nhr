  <!-- フッター（ネスト table なし・銀行行と印欄は rowspan で行数調整） -->
  <table class="footer-table">
    <colgroup>
      <col class="footer-col-bank-label" />
      <col />
      <col class="footer-col-stamp" />
      <col class="footer-col-tantou" />
    </colgroup>
    <tr>
      <td colspan="2" class="footer-note-cell">お振込は下記銀行宛にお願い致します。</td>
      <td class="col-stamp stamp-header">責　任　者　印</td>
      <td class="col-tantou stamp-header">担　当</td>
    </tr>
    <tr>
      <td class="footer-bank-label">銀　行　名</td>
      <td class="footer-bank-val">みずほ銀行</td>
      <td class="col-stamp stamp-body" rowspan="4">&nbsp;</td>
      <td class="col-tantou stamp-body" rowspan="4">&nbsp;</td>
    </tr>
    <tr>
      <td class="footer-bank-label">支　店　名</td>
      <td class="footer-bank-val">麹町支店</td>
    </tr>
