      <tr><td class="col-date">&nbsp;</td><td class="col-name">&nbsp;</td><td class="col-spec">&nbsp;</td><td class="col-qty">&nbsp;</td><td class="col-unit">&nbsp;</td><td class="col-price">&nbsp;</td><td class="col-amount">&nbsp;</td><td class="col-remarks">&nbsp;</td></tr>
      <tr><td class="col-date">&nbsp;</td><td class="col-name">&nbsp;</td><td class="col-spec">&nbsp;</td><td class="col-qty">&nbsp;</td><td class="col-unit">&nbsp;</td><td class="col-price">&nbsp;</td><td class="col-amount">&nbsp;</td><td class="col-remarks">&nbsp;</td></tr>
      <tr><td class="col-date">&nbsp;</td><td class="col-name">&nbsp;</td><td class="col-spec">&nbsp;</td><td class="col-qty">&nbsp;</td><td class="col-unit">&nbsp;</td><td class="col-price">&nbsp;</td><td class="col-amount">&nbsp;</td><td class="col-remarks">&nbsp;</td></tr>
      <tr><td class="col-date">&nbsp;</td><td class="col-name">&nbsp;</td><td class="col-spec">&nbsp;</td><td class="col-qty">&nbsp;</td><td class="col-unit">&nbsp;</td><td class="col-price">&nbsp;</td><td class="col-amount">&nbsp;</td><td class="col-remarks">&nbsp;</td></tr>
      <tr><td class="col-date">&nbsp;</td><td class="col-name">&nbsp;</td><td class="col-spec">&nbsp;</td><td class="col-qty">&nbsp;</td><td class="col-unit">&nbsp;</td><td class="col-price">&nbsp;</td><td class="col-amount">&nbsp;</td><td class="col-remarks">&nbsp;</td></tr>
